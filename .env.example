# ─── Telegram ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ─── AI Model (OpenAI-compatible aggregator) ─────────────────────────────────
API_KEY=your_api_key_here
API_BASE_URL=https://your-api-base-url/v1
MODEL_NAME=gemini-2.0-flash

# ─── Supabase Database ───────────────────────────────────────────────────────
# Get this from: Supabase → Settings → Database → URI (Transaction mode, port 6543)
DATABASE_URL=postgresql://postgres:[password]@[host]:6543/postgres

# ─── Vercel Webhook URL ───────────────────────────────────────────────────────
# Set this AFTER your first Vercel deployment
# Example: https://your-app-name.vercel.app
WEBHOOK_URL=

# ─── Authorization (optional) ────────────────────────────────────────────────
# Comma-separated Telegram user IDs
AUTHORIZED_TELEGRAM_IDS=

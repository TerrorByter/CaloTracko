# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Access Control / Security
REQUIRE_AUTH=True
AUTHORIZED_TELEGRAM_IDS=your_telegram_id_here,another_id_here

# AI Model Aggregator API Settings (OpenAI-compatible)
API_KEY=your_api_key_here
API_BASE_URL=https://api.apiyi.com/v1
MODEL_NAME=gpt-4o-mini

# Supabase Database (Transaction pooler, port 6543)
DATABASE_URL=postgresql://postgres:[password]@[host]:6543/postgres

# Webhook URL (Vercel deployment URL, set this AFTER deployment)
WEBHOOK_URL=https://your-app.vercel.app
